{
    "name": "terminal-iwkbu",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --hostname 0.0.0.0 --port 3000",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "test:integration": "node tests/integration/auth-smoke.mjs",
        "test:e2e": "pnpm build && node scripts/setup-e2e.mjs && npx playwright test",
        "test:e2e:dev": "node scripts/setup-e2e.mjs && npx playwright test",
        "test:e2e:setup": "node scripts/setup-e2e.mjs",
        "test:engine": "tsx --test src/lib/rekonsiliasi/engine.test.ts",
        "test:auth": "tsx --test src/lib/auth/actor.test.ts",
        "test:unit": "tsx --test src/lib/*.test.ts src/lib/**/*.test.ts",
        "deps:check": "pnpm outdated",
        "audit": "pnpm audit --audit-level=moderate",
        "size": "pnpm build && size-limit"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@sentry/node": "^10.53.1",
        "@sentry/react": "^10.53.1",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.108.2",
        "bcryptjs": "3.0.3",
        "clsx": "^2.1.1",
        "lucide-react": "^0.563.0",
        "next": "16.2.6",
        "pg": "^8.20.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.1",
        "recharts": "^3.7.0",
        "sonner": "^2.0.7",
        "styled-jsx": "^5.1.7",
        "supabase": "^2.107.0",
        "tailwind-merge": "^3.6.0",
        "xlsx": "^0.18.5",
        "zod": "^3.25.28"
    },
    "optionalDependencies": {
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.8"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@playwright/test": "^1.61.0",
        "@size-limit/preset-small-lib": "^12.1.0",
        "@supabase/mcp-server-supabase": "^0.8.2",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "daisyui": "^5.5.23",
        "eslint": "9.39.4",
        "eslint-config-next": "16.2.6",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "postcss": "8.5.14",
        "size-limit": "^12.1.0",
        "tailwindcss": "^4",
        "tsx": "^4.22.4",
        "typescript": "^5"
    },
    "size-limit": [
        {
            "path": [
                ".next/static/chunks/*.js",
                ".next/static/chunks/app/**/*.js"
            ],
            "limit": "1.1 MB"
        }
    ]
}
