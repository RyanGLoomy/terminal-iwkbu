# =============================================================================
# Terminal IWKBU — Environment Variables
# Copy this file to .env.local and fill in values.
# =============================================================================

# --- Required (app will not start without these) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Required for cron endpoints (POST /api/cron/iwkbu-sync, /api/cron/iwkbu-fetch) ---
# Set this to a strong random string. The cron caller must send it as:
#   Authorization: Bearer <IWKBU_SYNC_CRON_SECRET>
IWKBU_SYNC_CRON_SECRET=

# --- Optional: IWKBU external API adaptor (runs in mock mode without these) ---
# IWKBU_API_URL=
# IWKBU_API_KEY=

# --- Optional: Sentry error monitoring (no-op without DSN) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- CI/backup only (not used at runtime) ---
# SUPABASE_DB_URL=postgresql://...
